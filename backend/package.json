{
  "name": "@endgame-grocery/backend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "nodemon src/index.js",
    "build": "node --check src/index.js",
    "lint": "eslint .",
    "test": "node --test",
    "migrate": "node --env-file=../.env ../node_modules/node-pg-migrate/bin/node-pg-migrate.js up --migrations-dir src/db/migrations",
    "db:seed": "node src/db/seed.js"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "handlebars": "^4.7.9",
    "js-yaml": "^4.1.1",
    "jsonwebtoken": "^9.0.2",
    "node-pg-migrate": "^8.0.4",
    "nodemailer": "^8.0.7",
    "pg": "^8.14.1",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "swagger-ui-express": "^5.0.1",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "nodemon": "^3.1.10",
    "supertest": "^7.1.0"
  }
}
