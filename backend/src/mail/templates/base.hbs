<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{{appName}}</title>
  </head>
  <body style="margin: 0; padding: 24px 0; background: #10141f; color: #e5ecff; font-family: Arial, sans-serif;">
    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="border-collapse: collapse;">
      <tr>
        <td align="center">
          <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="max-width: 600px; border-collapse: collapse; background: #161d2e; border: 1px solid #2a3655; border-radius: 16px; overflow: hidden;">
            <tr>
              <td style="padding: 32px 32px 16px; background: linear-gradient(135deg, #1f2740 0%, #12192a 100%);">
                <p style="margin: 0; font-size: 12px; letter-spacing: 0.16em; text-transform: uppercase; color: #91a6d8;">{{appName}}</p>
                <h1 style="margin: 12px 0 0; font-size: 28px; line-height: 1.2; color: #ffffff;">{{heading}}</h1>
              </td>
            </tr>
            <tr>
              <td style="padding: 32px;">
                {{#if intro}}
                  <p style="margin: 0 0 16px; font-size: 16px; line-height: 1.6; color: #d8e1ff;">{{intro}}</p>
                {{/if}}
                {{#if body}}
                  <p style="margin: 0 0 24px; font-size: 16px; line-height: 1.6; color: #d8e1ff;">{{body}}</p>
                {{/if}}
                {{#if ctaUrl}}
                  <p style="margin: 0 0 24px;">
                    <a href="{{ctaUrl}}" style="display: inline-block; padding: 14px 20px; background: #72f2c0; color: #081019; text-decoration: none; font-weight: 700; border-radius: 999px;">
                      {{ctaLabel}}
                    </a>
                  </p>
                {{/if}}
                {{{content}}}
              </td>
            </tr>
            <tr>
              <td style="padding: 0 32px 32px; font-size: 13px; line-height: 1.5; color: #91a6d8;">
                <p style="margin: 0;">You received this message because an action in {{appName}} requested it.</p>
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
